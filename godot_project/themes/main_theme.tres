[gd_resource type="Theme" load_steps=12 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/Hina_Mincho/HinaMincho-Regular.ttf" id="1_hina"]
[ext_resource type="FontFile" path="res://assets/fonts/Kaisei_Tokumin/KaiseiTokumin-Regular.ttf" id="2_kaisei"]
[ext_resource type="FontFile" path="res://assets/fonts/yuji-syuku/YujiSyuku-Regular.ttf" id="3_yuji"]
[ext_resource type="FontFile" path="res://assets/fonts/EB_Garamond/static/EBGaramond-Regular.ttf" id="4_eb"]
[ext_resource type="FontFile" path="res://assets/fonts/Noto_Serif_SC/static/NotoSerifSC-Regular.ttf" id="5_noto_sc"]

[sub_resource type="FontVariation" id="FontVariation_body"]
base_font = ExtResource("1_hina")
fallbacks = Array[Font]([ExtResource("4_eb"), ExtResource("5_noto_sc")])

[sub_resource type="FontVariation" id="FontVariation_title"]
base_font = ExtResource("2_kaisei")
fallbacks = Array[Font]([ExtResource("4_eb"), ExtResource("5_noto_sc"), ExtResource("1_hina")])

[sub_resource type="FontVariation" id="FontVariation_special"]
base_font = ExtResource("3_yuji")
fallbacks = Array[Font]([ExtResource("4_eb"), ExtResource("5_noto_sc"), ExtResource("1_hina")])

